<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_menu_main"
    android:gravity="top"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_app">

    <LinearLayout
        android:id="@+id/icon_panel"
        android:layout_width="0dp"
        android:layout_height="@dimen/_42sdp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/icon_panel_bg"
        android:layout_marginHorizontal="@dimen/_7sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:paddingHorizontal="@dimen/_4sdp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/news_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_menu_news"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/mcl_tab_wiki" />

        <ImageButton
            android:id="@+id/social_media_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_discord"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/mcl_button_social_media" />

        <ImageButton
            android:id="@+id/custom_control_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_gamepad_pointer"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/mcl_option_customcontrol" />

        <ImageButton
            android:id="@+id/install_jar_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_menu_install_jar"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/main_install_jar_file" />

        <ImageButton
            android:id="@+id/share_logs_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_share_log"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/main_share_logs" />

        <ImageButton
            android:id="@+id/open_files_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_folder_open"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_8sdp"
            android:contentDescription="@string/mcl_button_open_directory" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/bottom_row"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:layout_marginHorizontal="@dimen/_7sdp"
        android:layout_marginTop="@dimen/_8sdp"
        android:layout_marginBottom="@dimen/_5sdp"
        app:layout_constraintTop_toBottomOf="@id/icon_panel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panel_1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/_4sdp"
            android:background="@drawable/panel_bg">

            <com.kdt.mcgui.mcVersionSpinner
                android:id="@+id/mc_version_spinner"
                android:layout_width="0dp"
                android:layout_height="@dimen/_45sdp"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_4sdp"
                android:background="@android:color/transparent"
                android:drawableEnd="@drawable/ic_spinner_arrow"
                app:drawableEndSize="@dimen/_12sdp"
                app:drawableStartIntegerScaling="true"
                app:drawableStartSize="@dimen/_36sdp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/play_row"
                android:layout_width="0dp"
                android:layout_height="@dimen/_40sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_marginBottom="@dimen/_4sdp"
                app:layout_constraintTop_toBottomOf="@id/mc_version_spinner"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.kdt.mcgui.MineButton
                    android:id="@+id/play_button"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/_6sdp"
                    android:text="@string/main_play"
                    android:textAllCaps="true" />

                <ImageButton
                    android:id="@+id/edit_profile_button"
                    android:layout_width="@dimen/_36sdp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_px_edit"
                    android:scaleType="fitCenter"
                    android:padding="@dimen/_6sdp" />

                <ImageButton
                    android:id="@+id/delete_profile_button"
                    android:layout_width="@dimen/_36sdp"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:src="@drawable/ic_px_trash"
                    android:tint="#E53935"
                    android:scaleType="fitCenter"
                    android:padding="@dimen/_6sdp" />

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/_4sdp"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/panel_2"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="@dimen/_2sdp"
                android:background="@drawable/panel_bg" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/panel_3"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/_2sdp"
                android:background="@drawable/panel_bg" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
