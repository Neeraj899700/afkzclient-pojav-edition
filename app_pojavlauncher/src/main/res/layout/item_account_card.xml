<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/account_card_bg"
    android:layout_marginBottom="@dimen/_8sdp"
    android:padding="@dimen/_12sdp">

    <!-- Top row: avatar + info + actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Skin head avatar -->
        <FrameLayout
            android:layout_width="@dimen/_48sdp"
            android:layout_height="@dimen/_48sdp"
            android:layout_marginEnd="@dimen/_12sdp">

            <ImageView
                android:id="@+id/account_avatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@drawable/avatar_circle_bg"
                android:contentDescription="Account skin" />

            <!-- Auth type badge -->
            <ImageView
                android:id="@+id/account_badge"
                android:layout_width="@dimen/_18sdp"
                android:layout_height="@dimen/_18sdp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/badge_circle_bg"
                android:padding="@dimen/_3sdp"
                android:scaleType="centerInside"
                android:contentDescription="Auth type" />
        </FrameLayout>

        <!-- Username + auth type text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/account_username"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/_14ssp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/account_auth_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/muted_text"
                android:textSize="@dimen/_10ssp"
                android:layout_marginTop="@dimen/_2sdp" />
        </LinearLayout>

        <!-- Selected indicator -->
        <FrameLayout
            android:id="@+id/selected_indicator"
            android:layout_width="@dimen/_24sdp"
            android:layout_height="@dimen/_24sdp"
            android:layout_marginEnd="@dimen/_8sdp"
            android:visibility="gone">

            <View
                android:layout_width="@dimen/_12sdp"
                android:layout_height="@dimen/_12sdp"
                android:layout_gravity="center"
                android:background="@drawable/selected_dot_bg" />
        </FrameLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_refresh"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@drawable/overlay_button_bg"
                android:src="@drawable/ic_px_edit"
                android:tint="@color/minebutton_color"
                android:scaleType="center"
                android:padding="@dimen/_6sdp"
                android:layout_marginEnd="@dimen/_4sdp"
                android:contentDescription="Refresh" />

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="@dimen/_32sdp"
                android:layout_height="@dimen/_32sdp"
                android:background="@drawable/overlay_button_bg"
                android:src="@drawable/ic_px_trash"
                android:tint="@color/accent_red"
                android:scaleType="center"
                android:padding="@dimen/_6sdp"
                android:contentDescription="Delete" />
        </LinearLayout>
    </LinearLayout>

    <!-- Status bar (token expiry etc) -->
    <LinearLayout
        android:id="@+id/account_status_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="@dimen/_8sdp"
        android:gravity="center_vertical">

        <View
            android:id="@+id/status_dot"
            android:layout_width="@dimen/_6sdp"
            android:layout_height="@dimen/_6sdp"
            android:background="@drawable/selected_dot_bg"
            android:layout_marginEnd="@dimen/_6sdp" />

        <TextView
            android:id="@+id/account_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/muted_text"
            android:textSize="@dimen/_9ssp"
            android:singleLine="true" />
    </LinearLayout>
</LinearLayout>
