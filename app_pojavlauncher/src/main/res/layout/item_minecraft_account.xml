<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="@dimen/_48sdp"
    android:layout_width="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="@dimen/_12sdp"
    android:background="@drawable/account_item_bg"
    android:paddingStart="@dimen/_12sdp"
    android:paddingEnd="@dimen/_4sdp">

    <fr.spse.extended_view.ExtendedTextView
        android:id="@+id/account_item"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:textSize="@dimen/_14ssp"
        android:textColor="@color/primary_text"
        android:gravity="center_vertical"
        android:drawablePadding="@dimen/_10sdp"
        android:paddingStart="@dimen/_8sdp"
        app:drawableStartSize="@dimen/_32sdp"
        app:drawableEndSize="@dimen/_24sdp"
        tools:text="HELLO THERE"
        tools:drawableStart="@mipmap/ic_launcher"
        tools:ignore="RtlSymmetry" />

    <ImageView
        android:id="@+id/dropdown_arrow"
        android:layout_width="@dimen/_24sdp"
        android:layout_height="@dimen/_24sdp"
        android:src="@drawable/ic_spinner_arrow"
        android:scaleType="center"
        android:visibility="gone"
        tools:visibility="visible"
        android:contentDescription="@null" />

    <ImageView
        android:id="@+id/delete_account_button"
        android:layout_width="@dimen/_40sdp"
        android:layout_height="@dimen/_40sdp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_px_trash"
        android:tint="#E53935"
        android:scaleType="center"
        android:padding="@dimen/_10sdp" />

</LinearLayout>
