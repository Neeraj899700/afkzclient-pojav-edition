<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:orientation="vertical"
    android:padding="@dimen/_7sdp">

    <!-- Profile selector -->
    <TextView
        android:id="@+id/instance_selector"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:background="@drawable/panel_bg"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/_12sdp"
        android:drawableEnd="@drawable/ic_spinner_arrow"
        android:textSize="@dimen/_13ssp"
        android:textColor="@color/primary_text"
        android:text="@string/no_instance" />

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/_42sdp"
        android:layout_marginTop="@dimen/_8sdp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/icon_panel_bg"
        android:padding="@dimen/_2sdp">

        <Button
            android:id="@+id/tab_meta"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="@dimen/_2sdp"
            android:background="@drawable/tab_btn_bg"
            android:text="Meta"
            android:textAllCaps="false"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/tab_text_color" />

        <Button
            android:id="@+id/tab_mods"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="@dimen/_2sdp"
            android:background="@drawable/tab_btn_bg"
            android:text="Mods"
            android:textAllCaps="false"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/tab_text_color" />

        <Button
            android:id="@+id/tab_resourcepacks"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_margin="@dimen/_2sdp"
            android:background="@drawable/tab_btn_bg"
            android:text="Resource Packs"
            android:textAllCaps="false"
            android:textSize="@dimen/_11ssp"
            android:textColor="@color/tab_text_color" />
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/_8sdp"
        android:background="@drawable/panel_bg"
        android:padding="@dimen/_8sdp">

        <!-- Meta content -->
        <ScrollView
            android:id="@+id/meta_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/meta_name_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Name"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/meta_version_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Version"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_version"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/meta_runtime_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Runtime"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_runtime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/meta_renderer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Renderer"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_renderer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/meta_jvm_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JVM Args"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_jvm"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/_8sdp"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

                <TextView
                    android:id="@+id/meta_control_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Control Layout"
                    android:textColor="#888888"
                    android:textSize="@dimen/_11ssp" />
                <TextView
                    android:id="@+id/meta_control"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/primary_text"
                    android:textSize="@dimen/_13ssp" />

            </LinearLayout>
        </ScrollView>

        <!-- Mods list -->
        <ListView
            android:id="@+id/mods_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:divider="#33FFFFFF"
            android:dividerHeight="1dp" />

        <!-- Resource packs list -->
        <ListView
            android:id="@+id/resourcepacks_list"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:divider="#33FFFFFF"
            android:dividerHeight="1dp" />

    </FrameLayout>

</LinearLayout>
