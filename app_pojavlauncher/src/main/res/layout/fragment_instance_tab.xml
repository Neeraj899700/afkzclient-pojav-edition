<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:orientation="vertical"
    android:padding="@dimen/_7sdp">

    <!-- Profile selector -->
    <TextView
        android:id="@+id/instance_selector"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:background="@drawable/panel_bg"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/_12sdp"
        android:drawableEnd="@drawable/ic_spinner_arrow"
        android:textSize="@dimen/_13ssp"
        android:textColor="@color/primary_text"
        android:text="@string/no_instance" />

    <!-- Tab buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_meta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="@dimen/_8sdp"
                android:text="Meta"
                android:textSize="@dimen/_13ssp"
                android:textColor="@color/minebutton_color"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tab_mods"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="@dimen/_8sdp"
                android:text="Mods"
                android:textSize="@dimen/_13ssp"
                android:textColor="@color/tab_text_inactive" />

            <TextView
                android:id="@+id/tab_resourcepacks"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="@dimen/_8sdp"
                android:text="Resource Packs"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/tab_text_inactive" />

            <TextView
                android:id="@+id/tab_screenshots"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:padding="@dimen/_8sdp"
                android:text="Screenshots"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/tab_text_inactive" />
        </LinearLayout>

        <!-- Tab underline indicator -->
        <View
            android:id="@+id/tab_indicator"
            android:layout_width="0dp"
            android:layout_height="@dimen/_2sdp"
            android:background="@color/minebutton_color" />
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/_6sdp">

        <!-- Meta content -->
        <ScrollView
            android:id="@+id/meta_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:fadeScrollbars="true"
            android:scrollbarThumbVertical="@color/minebutton_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Identity Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROFILE IDENTITY"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <FrameLayout
                        android:layout_width="@dimen/_56sdp"
                        android:layout_height="@dimen/_56sdp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/_8sdp">

                        <ImageView
                            android:id="@+id/editor_icon"
                            android:layout_width="@dimen/_50sdp"
                            android:layout_height="@dimen/_50sdp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:layout_width="@dimen/_14sdp"
                            android:layout_height="@dimen/_14sdp"
                            android:layout_gravity="bottom|end"
                            android:src="@drawable/ic_px_edit"
                            android:background="@drawable/background_icon_edit" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="Name"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <EditText
                        android:id="@+id/editor_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Profile name"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Version"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/editor_version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Select version"
                            android:clickable="true"
                            android:focusable="true" />

                        <Button
                            android:id="@+id/editor_version_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Select"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_11ssp"
                            android:textColor="@color/primary_text"
                            android:paddingHorizontal="@dimen/_10sdp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Disk Usage"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <TextView
                        android:id="@+id/editor_disk_usage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Calculating..." />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Last Played"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <TextView
                        android:id="@+id/editor_last_played"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Never" />
                </LinearLayout>

                <!-- Runtime Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RUNTIME"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Java Runtime"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <Spinner
                        android:id="@+id/editor_runtime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Renderer"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <Spinner
                        android:id="@+id/editor_renderer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line" />
                </LinearLayout>

                <!-- Advanced Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADVANCED"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="JVM Arguments"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <EditText
                        android:id="@+id/editor_jvm_args"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Additional JVM args"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Control Layout"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/editor_control"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Default" />

                        <Button
                            android:id="@+id/editor_control_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Select"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_11ssp"
                            android:textColor="@color/primary_text"
                            android:paddingHorizontal="@dimen/_10sdp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Shared Data"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <CheckBox
                        android:id="@+id/editor_shared_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:text="Use shared data directory"
                        android:textColor="@color/primary_text"
                        android:button="@null" />

                    <!-- Resolution override -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Resolution Override (0 = default)"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/editor_res_width"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/_4sdp"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Width"
                            android:inputType="number"
                            android:singleLine="true" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="x"
                            android:textColor="@color/muted_text"
                            android:textSize="@dimen/_13ssp"
                            android:paddingHorizontal="@dimen/_4sdp" />

                        <EditText
                            android:id="@+id/editor_res_height"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/_4sdp"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Height"
                            android:inputType="number"
                            android:singleLine="true" />
                    </LinearLayout>

                    <!-- Account per profile -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Account"
                        android:textColor="@color/muted_text"
                        android:textSize="@dimen/_11ssp" />
                    <Spinner
                        android:id="@+id/editor_account"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line" />
                </LinearLayout>

                <!-- Action Buttons Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/editor_save"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/_4sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Save"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_13ssp"
                            android:textColor="@color/primary_text" />

                        <Button
                            android:id="@+id/editor_delete"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/_4sdp"
                            android:background="@drawable/stop_button_background"
                            android:text="Delete"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_13ssp"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editor_open_dir"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Open Game Directory"
                        android:textAllCaps="false"
                        android:textSize="@dimen/_13ssp"
                        android:textColor="@color/primary_text" />

                    <Button
                        android:id="@+id/editor_duplicate"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Duplicate Profile"
                        android:textAllCaps="false"
                        android:textSize="@dimen/_13ssp"
                        android:textColor="@color/primary_text" />

                    <Button
                        android:id="@+id/editor_export"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Export Profile"
                        android:textAllCaps="false"
                        android:textSize="@dimen/_13ssp"
                        android:textColor="@color/primary_text" />
                </LinearLayout>

                <!-- Screenshots Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SCREENSHOTS"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:id="@+id/editor_screenshots_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:text="No screenshots" />

                    <Button
                        android:id="@+id/editor_open_screenshots"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Open Screenshots Folder"
                        android:textAllCaps="false"
                        android:textSize="@dimen/_13ssp"
                        android:textColor="@color/primary_text" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Mods container -->
        <LinearLayout
            android:id="@+id/mods_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical">

            <!-- Mods header with open folder button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/panel_bg"
                android:padding="@dimen/_8sdp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="@dimen/_4sdp">

                <TextView
                    android:id="@+id/mods_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/_12ssp"
                    android:textColor="@color/primary_text" />

                <ImageView
                    android:id="@+id/mods_open_folder"
                    android:layout_width="@dimen/_32sdp"
                    android:layout_height="@dimen/_32sdp"
                    android:background="@drawable/overlay_button_bg"
                    android:src="@drawable/ic_set_download"
                    android:tint="@color/minebutton_color"
                    android:scaleType="centerInside"
                    android:padding="@dimen/_6sdp"
                    android:contentDescription="Open mods folder" />
            </LinearLayout>

            <EditText
                android:id="@+id/mods_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_line"
                android:padding="@dimen/_8sdp"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/_12ssp"
                android:hint="Search mods..."
                android:singleLine="true"
                android:layout_marginBottom="@dimen/_4sdp" />

            <ListView
                android:id="@+id/mods_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="@null"
                android:dividerHeight="0dp" />
        </LinearLayout>

        <!-- Resource packs container -->
        <LinearLayout
            android:id="@+id/resourcepacks_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical">

            <EditText
                android:id="@+id/resourcepacks_search"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/background_line"
                android:padding="@dimen/_8sdp"
                android:textColor="@color/primary_text"
                android:textSize="@dimen/_12ssp"
                android:hint="Search resource packs..."
                android:singleLine="true"
                android:layout_marginBottom="@dimen/_4sdp" />

            <TextView
                android:id="@+id/resourcepacks_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/panel_bg"
                android:padding="@dimen/_8sdp"
                android:gravity="center"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="@dimen/_4sdp" />

            <ListView
                android:id="@+id/resourcepacks_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null"
                android:dividerHeight="0dp" />
        </LinearLayout>

        <!-- Screenshots container -->
        <ScrollView
            android:id="@+id/screenshots_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:fadeScrollbars="true"
            android:scrollbarThumbVertical="@color/minebutton_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Screenshots header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_8sdp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/_4sdp">

                    <TextView
                        android:id="@+id/screenshots_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textSize="@dimen/_12ssp"
                        android:textColor="@color/primary_text" />

                    <Button
                        android:id="@+id/screenshots_open_folder"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/_32sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Open Folder"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_10ssp"
                        android:minWidth="0dp"
                        android:paddingHorizontal="@dimen/_8sdp" />
                </LinearLayout>

                <!-- Screenshots grid (built programmatically) -->
                <LinearLayout
                    android:id="@+id/screenshots_grid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/screenshots_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/_24sdp"
                    android:text="No screenshots yet"
                    android:textColor="@color/muted_text"
                    android:textSize="@dimen/_13ssp"
                    android:visibility="gone" />
            </LinearLayout>
        </ScrollView>

    </FrameLayout>

</LinearLayout>
