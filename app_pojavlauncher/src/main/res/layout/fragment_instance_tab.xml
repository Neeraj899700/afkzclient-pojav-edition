<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app"
    android:orientation="vertical"
    android:padding="@dimen/_7sdp">

    <!-- Profile selector -->
    <TextView
        android:id="@+id/instance_selector"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_45sdp"
        android:background="@drawable/panel_bg"
        android:gravity="center_vertical|start"
        android:paddingHorizontal="@dimen/_12sdp"
        android:drawableEnd="@drawable/ic_spinner_arrow"
        android:textSize="@dimen/_13ssp"
        android:textColor="@color/primary_text"
        android:text="@string/no_instance" />

    <!-- Tab buttons (no background) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_8sdp"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/tab_meta"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_8sdp"
            android:text="Meta"
            android:textSize="@dimen/_13ssp"
            android:textColor="@color/primary_text" />

        <TextView
            android:id="@+id/tab_mods"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_8sdp"
            android:text="Mods"
            android:textSize="@dimen/_13ssp"
            android:textColor="@color/primary_text" />

        <TextView
            android:id="@+id/tab_resourcepacks"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:padding="@dimen/_8sdp"
            android:text="Resource Packs"
            android:textSize="@dimen/_12ssp"
            android:textColor="@color/primary_text" />
    </LinearLayout>

    <!-- Content area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="@dimen/_6sdp">

        <!-- Meta content - premium card editor -->
        <ScrollView
            android:id="@+id/meta_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible"
            android:fadeScrollbars="true"
            android:scrollbarThumbVertical="@color/minebutton_color">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Identity Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PROFILE IDENTITY"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <FrameLayout
                        android:layout_width="@dimen/_56sdp"
                        android:layout_height="@dimen/_56sdp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="@dimen/_8sdp">

                        <ImageView
                            android:id="@+id/editor_icon"
                            android:layout_width="@dimen/_50sdp"
                            android:layout_height="@dimen/_50sdp"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter" />

                        <ImageView
                            android:layout_width="@dimen/_14sdp"
                            android:layout_height="@dimen/_14sdp"
                            android:layout_gravity="bottom|end"
                            android:src="@drawable/ic_px_edit"
                            android:background="@drawable/background_icon_edit" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_8sdp"
                        android:text="Name"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <EditText
                        android:id="@+id/editor_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Profile name"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Version"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/editor_version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Select version"
                            android:clickable="true"
                            android:focusable="true" />

                        <Button
                            android:id="@+id/editor_version_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Select"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_11ssp"
                            android:textColor="#121213"
                            android:paddingHorizontal="@dimen/_10sdp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Disk Usage"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <TextView
                        android:id="@+id/editor_disk_usage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Calculating..." />
                </LinearLayout>

                <!-- Runtime Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RUNTIME"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Java Runtime"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <Spinner
                        android:id="@+id/editor_runtime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Renderer"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <Spinner
                        android:id="@+id/editor_renderer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line" />
                </LinearLayout>

                <!-- Advanced Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ADVANCED"
                        android:textColor="@color/minebutton_color"
                        android:textSize="@dimen/_10ssp"
                        android:textStyle="bold"
                        android:letterSpacing="0.08" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="JVM Arguments"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <EditText
                        android:id="@+id/editor_jvm_args"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:textColor="@color/primary_text"
                        android:textSize="@dimen/_13ssp"
                        android:hint="Additional JVM args"
                        android:singleLine="true" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Control Layout"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/editor_control"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:background="@drawable/background_line"
                            android:padding="@dimen/_8sdp"
                            android:textColor="@color/primary_text"
                            android:textSize="@dimen/_13ssp"
                            android:hint="Default" />

                        <Button
                            android:id="@+id/editor_control_button"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_6sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Select"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_11ssp"
                            android:textColor="#121213"
                            android:paddingHorizontal="@dimen/_10sdp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:text="Shared Data"
                        android:textColor="#888888"
                        android:textSize="@dimen/_11ssp" />
                    <CheckBox
                        android:id="@+id/editor_shared_data"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_4sdp"
                        android:background="@drawable/background_line"
                        android:padding="@dimen/_8sdp"
                        android:text="Use shared data directory"
                        android:textColor="@color/primary_text"
                        android:button="@null" />
                </LinearLayout>

                <!-- Action Buttons Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/panel_bg"
                    android:padding="@dimen/_12sdp"
                    android:layout_marginBottom="@dimen/_6sdp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/editor_save"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/_4sdp"
                            android:background="@drawable/mine_button_background"
                            android:text="Save"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_13ssp"
                            android:textColor="#121213" />

                        <Button
                            android:id="@+id/editor_delete"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/_42sdp"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/_4sdp"
                            android:background="@drawable/stop_button_background"
                            android:text="Delete"
                            android:textAllCaps="false"
                            android:textSize="@dimen/_13ssp"
                            android:textColor="#FFFFFF" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/editor_open_dir"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_42sdp"
                        android:layout_marginTop="@dimen/_6sdp"
                        android:background="@drawable/mine_button_background"
                        android:text="Open Game Directory"
                        android:textAllCaps="false"
                        android:textSize="@dimen/_13ssp"
                        android:textColor="#121213" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Mods list -->
        <LinearLayout
            android:id="@+id/mods_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical">

            <TextView
                android:id="@+id/mods_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/panel_bg"
                android:padding="@dimen/_8sdp"
                android:gravity="center"
                android:textSize="@dimen/_12ssp"
                android:textColor="@color/primary_text"
                android:layout_marginBottom="@dimen/_4sdp" />

            <ListView
                android:id="@+id/mods_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:divider="#33FFFFFF"
                android:dividerHeight="1dp" />
        </LinearLayout>

        <!-- Resource packs list -->
        <LinearLayout
            android:id="@+id/resourcepacks_container"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:orientation="vertical">

            <ListView
                android:id="@+id/resourcepacks_list"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="#33FFFFFF"
                android:dividerHeight="1dp" />
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
