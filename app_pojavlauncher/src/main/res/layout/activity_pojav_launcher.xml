<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_app">

    <!-- Account panel: 70% width, right-aligned, clean design -->
    <com.kdt.mcgui.AccountSpinner
        android:id="@+id/account_spinner"
        android:layout_width="0dp"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginTop="@dimen/_4sdp"
        android:layout_marginEnd="@dimen/padding_medium"
        android:background="@drawable/panel_account_spinner_bg"
        android:dropDownWidth="@dimen/_250sdp"
        android:dropDownVerticalOffset="@dimen/_44sdp"
        android:paddingStart="@dimen/padding_small"
        android:paddingEnd="@dimen/_8sdp"
        android:spinnerMode="dropdown"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintWidth_percent="0.7" />

    <!-- Progress bar between top area and icon panel -->
    <ProgressBar
        android:id="@+id/top_progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:indeterminate="false"
        android:max="100"
        android:progress="0"
        android:progressTint="@color/minebutton_color"
        android:backgroundTint="@color/background_overlay"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/account_spinner"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/container_fragment"
        android:name="net.kdt.pojavlaunch.fragments.MainMenuFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/bottom_nav_panel"
        app:layout_constraintTop_toBottomOf="@+id/top_progress_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom nav bar -->
    <LinearLayout
        android:id="@+id/bottom_nav_panel"
        android:layout_width="0dp"
        android:layout_height="@dimen/_52sdp"
        android:layout_marginHorizontal="@dimen/_17sdp"
        android:layout_marginBottom="@dimen/_4sdp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/nav_bar_bg"
        app:layout_constraintBottom_toTopOf="@+id/progress_layout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/nav_home_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_home"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_10sdp"
            android:contentDescription="Home" />

        <ImageButton
            android:id="@+id/nav_instance_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_instance"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_10sdp"
            android:contentDescription="Instance" />

        <ImageButton
            android:id="@+id/nav_account_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_account"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_10sdp"
            android:contentDescription="Account" />

        <ImageButton
            android:id="@+id/nav_settings_button"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:src="@drawable/ic_nav_settings"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:scaleType="fitCenter"
            android:padding="@dimen/_10sdp"
            android:contentDescription="Settings" />

    </LinearLayout>

    <com.kdt.mcgui.ProgressLayout
        android:id="@+id/progress_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
